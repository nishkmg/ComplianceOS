{
  "name": "@complianceos/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./seed/coa-templates/*.json": "./src/seed/coa-templates/*.json"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/seed/index.ts",
    "db:seed:demo": "SEED_DEMO=true tsx src/seed/index.ts",
    "db:seed:demo:clean": "SEED_DEMO=true CLEAN_DEMO=true tsx src/seed/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^1.6.1"
  }
}
