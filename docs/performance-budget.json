{
  "performance-budget": {
    "resource-sizes": {
      "total": { "maxSize": 500 * 1024 },
      "script": { "maxSize": 200 * 1024 },
      "font": { "maxSize": 150 * 1024 },
      "stylesheet": { "maxSize": 50 * 1024 }
    },
    "timings": {
      "first-contentful-paint": 3000,
      "largest-contentful-paint": 5000,
      "interactive": 6000,
      "total-blocking-time": 500,
      "cumulative-layout-shift": 0.25
    }
  },
  "rules": {
    "react-performance": {
      "no-unnecessary-re-renders": true,
      "prefer-use-memo": true,
      "prefer-use-callback": true
    },
    "image-optimization": {
      "prefer-webp": true,
      "lazy-load-above-fold": false,
      "lazy-load-below-fold": true
    }
  }
}
